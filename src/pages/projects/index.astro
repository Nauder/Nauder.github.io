---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Projects" description="A collection of projects I've built.">
  <div class="container page">
    <header class="page-header">
      <p class="section-label">Work</p>
      <h1>Projects</h1>
      <p class="lead">A collection of things I've built: personal projects, open-source contributions, and experiments.</p>
    </header>

    <div class="grid">
      {projects.map(p => (
        <ProjectCard
          title={p.data.title}
          description={p.data.description}
          tags={p.data.tags}
          slug={p.id.replace(/\.mdx?$/, '')}
          github={p.data.github}
          demo={p.data.demo}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding-top: 4rem;
    padding-bottom: 2rem;
  }

  .page-header {
    margin-bottom: 3rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 2.75rem);
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }

  .lead {
    color: var(--text-muted);
    max-width: 520px;
    line-height: 1.75;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }
</style>
